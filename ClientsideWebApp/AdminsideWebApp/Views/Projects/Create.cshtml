@model ProjectModel
@using Microsoft.AspNetCore.Identity
@inject UserManager<IdentityUser> UserManager

<div class="admin-container">

    <div class="admin-header">
        <h1 class="admin-title">Uus projekt</h1>
        <p class="admin-subtitle">Lisa uus projekt</p>
    </div>

    <div class="admin-card">
        <form asp-action="Create" method="post">

            <div class="form-group">
                <label asp-for="Title" class="form-label">Pealkiri</label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Description" class="form-label">Kirjeldus</label>
                <textarea asp-for="Description" class="form-control" rows="5"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Status" class="form-label">Staatus</label>
                <select asp-for="Status" asp-items="ViewBag.Statuses" class="form-control"></select>
            </div>

            @if (User.IsInRole("Admin"))
            {
                <div class="form-group">
                    <label asp-for="UserId" class="form-label">Vastutaja</label>
                    <select asp-for="UserId" asp-items="ViewBag.Users" class="form-control">
                        <option value="">Pole määratud</option>
                    </select>
                </div>
            }

            <div class="form-actions center">
                <button type="submit" class="btn-primary">Salvesta</button>

                <a asp-action="Index" class="btn-secondary-custom">
                    Tagasi
                </a>
            </div>

        </form>
    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}