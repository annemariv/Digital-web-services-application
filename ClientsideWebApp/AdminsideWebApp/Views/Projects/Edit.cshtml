@model ProjectModel
@using Microsoft.AspNetCore.Identity
@inject UserManager<IdentityUser> UserManager

<div class="admin-container">

    <div class="admin-card">
        <div class="admin-header">
            <h2 class="admin-title">Uuenda projekti andmeid</h2>
        </div>

        <form asp-action="Edit" method="post">

            <input type="hidden" asp-for="Id" />

            <div class="form-group">
                <label asp-for="Title" class="form-label">Pealkiri</label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Description" class="form-label">Kirjeldus</label>
                <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Status" class="form-label">Staatus</label>
                <select asp-for="Status" asp-items="ViewBag.Statuses" class="form-control"></select>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>

            @if (User.IsInRole("Admin"))
            {
                <div class="form-group">
                    <label asp-for="UserId" class="form-label">Vastutaja</label>
                    <select asp-for="UserId" asp-items="ViewBag.Users" class="form-control">
                        <option value="">Pole määratud</option>
                    </select>
                    <span asp-validation-for="UserId" class="text-danger"></span>
                </div>
            }
            else
            {
                <div class="form-group">
                    <label class="form-label">Vastutaja</label>
                    <input class="form-control" value="@( (await UserManager.FindByIdAsync(Model.UserId))?.UserName ?? "Pole määratud" )" readonly />
                    <input type="hidden" asp-for="UserId" />
                </div>
            }

            <div class="form-actions center">

                <button type="submit" class="btn-primary">
                    Salvesta
                </button>

                <a asp-action="Index" class="btn-secondary-custom">
                    Tagasi
                </a>

            </div>
        </form>
    </div>
</div>