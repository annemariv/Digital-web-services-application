@model IEnumerable<ProjectModel>

<div class="admin-container">

    <div class="admin-header">
        <h1 class="admin-title">Projektid</h1>
        <p class="admin-subtitle">Kõik projektid</p>
    </div>

    <div class="admin-card">

        <div style="margin-bottom:15px;">
            <a asp-action="Create" class="btn-primary">+ Lisa projekt</a>
        </div>

        <table class="admin-table">
            <thead>
                <tr>
                    <th>Pealkiri</th>
                    <th>Staatus</th>
                    <th>Loodud</th>
                    <th style="text-align:right;">Tegevused</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Title</td>

                        <td>
                            <span class="status-badge status-@item.Status.ToLower()">
                                @item.StatusDisplay
                            </span>
                        </td>

                        <td>@item.CreatedAt.ToShortDateString()</td>

                        <td style="text-align:right;">

                            <a asp-action="Details" asp-route-id="@item.Id" class="icon-btn view" title="Vaata">
                                <i class="bi bi-eye-fill"></i>
                            </a>

                            <a asp-action="Edit" asp-route-id="@item.Id" class="icon-btn" title="Muuda">
                                <i class="bi bi-pencil"></i>
                            </a>

                            <a asp-action="Delete" asp-route-id="@item.Id" class="icon-btn delete" title="Kustuta">
                                <i class="bi bi-trash"></i>
                            </a>

                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>