@model IEnumerable<ProjectModel>

<div class="admin-container">

    <div class="admin-header">
        <h1 class="admin-title">Projektid</h1>
        <p class="admin-subtitle">Kõik projektid</p>
    </div>

    <div class="admin-card">

        <div class="table-header">
            <a asp-action="Create" class="btn-primary">+ Lisa projekt</a>
        </div>

        <table class="admin-table">
            <thead>
                <tr>
                    <th>Pealkiri</th>
                    <th>Staatus</th>
                    <th>Loodud</th>
                    <th>Uuendatud</th>
                    <th class="text-center">Tegevused</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Title</td>

                        <td>
                            <span class="status-badge status-@item.Status.ToLower()">
                                @item.StatusDisplay
                            </span>
                        </td>

                        <td>@item.CreatedAt.ToShortDateString()</td>
                        <td>
                            @(item.UpdatedAt?.ToShortDateString() ?? "-")
                        </td>

                        <td class="text-center">

                            <a asp-action="Details" asp-route-id="@item.Id" class="icon-btn view" title="Vaata">
                                <i class="bi bi-eye-fill"></i>
                            </a>

                            <a asp-action="Edit" asp-route-id="@item.Id" class="icon-btn" title="Muuda">
                                <i class="bi bi-pencil"></i>
                            </a>

                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-action="Delete" asp-route-id="@item.Id" class="icon-btn delete" title="Kustuta">
                                    <i class="bi bi-trash"></i>
                                </a>
                            }

                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>