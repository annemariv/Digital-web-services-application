@{
    ViewData["Title"] = "Home Page";
}

@model HomeViewModel

<div class="text-center">
    <section class="text-center py-5">
        <div class="container">
            <h1 class="hero-title mb-3">Teenused</h1>
            <p class="hero-subtitle mb-4">Pakume kaasaegseid ja usaldusväärseid lahendusi sinu ettevõttele</p>
        </div>
    </section>

    <section id="services" class="services-section py-5">
        <div class="container">
            <div class="row g-4">
                @foreach (var service in Model.Services)
                {
                    <div class="col-md-4">
                        <div class="service-card text-center"
                             data-bs-toggle="modal"
                             data-bs-target="#modal-@service.Id">

                            <div class="service-icon">@Html.Raw(service.Icon)</div>
                            <h5>@service.Title</h5>
                            <p>@service.ShortDescription</p>
                        </div>
                    </div>

                    <!-- modal -->
                    <div class="modal fade" id="modal-@service.Id" tabindex="-1">
                        <div class="modal-dialog modal-dialog-centered">
                            <div class="modal-content">

                                <div class="modal-header">
                                    <h5 class="modal-title">@service.Title</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                </div>

                                <div class="modal-body">
                                    <p>@service.FullDescription</p>

                                    <a href="#quote"
                                       class="btn hero-btn select-service-btn mt-3"
                                       data-service="@service.Id"
                                       data-bs-dismiss="modal">
                                        Küsi hinnapakkumist sellele teenusele
                                    </a>
                                </div>

                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>

    <section id="quote" class="quote-section py-5">
        <div class="container">
            <div class="quote-card mx-auto">
                <h4 class="mb-3 text-center">Küsi hinnapakkumist</h4>

                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success">@TempData["Success"]</div>
                }

                <form asp-action="Index" method="post">
                    <div class="mb-3">
                        <select asp-for="Quote.Service" class="form-control" required>
                            <option value="" disabled selected>Vali teenus</option>
                            <option value="web">Veebiarendus</option>
                            <option value="design">Disain</option>
                            <option value="accounting">Raamatupidamine</option>
                        </select>
                        <span asp-validation-for="Quote.Service" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <input asp-for="Quote.Name" class="form-control" placeholder="Nimi" required />
                        <span asp-validation-for="Quote.Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <input asp-for="Quote.Email" class="form-control" placeholder="E-post" required />
                        <span asp-validation-for="Quote.Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <textarea asp-for="Quote.Description"
                        class="form-control"
                        rows="4"
                        maxlength="1000"
                        placeholder="Kirjeldus"
                        autocomplete="off"></textarea>
                    </div>

                    <button type="submit" class="btn hero-btn w-100">Saada päring</button>
                </form>
            </div>
        </div>
    </section>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }
</div>
