@{
    ViewData["Title"] = "Home Page";
}

@model ClientsideWebApp.Models.ContactModel

<div class="text-center">
    <section class="text-center py-5">
        <div class="container">
            <h1 class="hero-title mb-3">Teenused</h1>
            <p class="hero-subtitle mb-4">Pakume kaasaegseid ja usaldusväärseid lahendusi sinu ettevõttele</p>
            <a href="#contact" class="btn hero-btn">Küsi hinnapakkumist</a>
        </div>
    </section>

    <section class="services-section py-5">
        <div class="container">
            <div class="row g-4">
                <div class="col-md-4">

                    <!-- WebDevelopment -->
                    <div class="service-card text-center">
                        <div class="service-icon">&#128187;</div>
                        <h5>Veebiarendus</h5>
                        <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>
                    </div>
                </div>

                <!-- WebDesign -->
                <div class="col-md-4">
                    <div class="service-card text-center">
                        <div class="service-icon">&#127912;</div>
                        <h5>Disain</h5>
                        <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>
                    </div>
                </div>

                <!-- Accounting -->
                <div class="col-md-4">
                    <div class="service-card text-center">
                        <div class="service-icon">&#128200;</div>
                        <h5>Raamatupidamine</h5>
                        <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section id="contact" class="contact-section py-5">
        <div class="container">
            <div class="contact-card mx-auto">
                <h4 class="mb-3 text-center">Küsi hinnapakkumist</h4>

                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success">@TempData["Success"]</div>
                }

                <form asp-action="Index" method="post">
                    <div class="mb-3">
                        <select asp-for="Service" class="form-control" required>
                            <option value="" disabled selected>Vali teenus</option>
                            <option value="web">Veebiarendus</option>
                            <option value="design">Disain</option>
                            <option value="accounting">Raamatupidamine</option>
                        </select>
                        <span asp-validation-for="Service" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <input asp-for="Name" class="form-control" placeholder="Nimi" required />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <input asp-for="Email" class="form-control" placeholder="E-post" required />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <textarea asp-for="Description" class="form-control" rows="4" placeholder="Kirjeldus" autocomplete="off"></textarea>
                    </div>

                    <button type="submit" class="btn hero-btn w-100">Saada päring</button>
                </form>
            </div>
        </div>
    </section>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }
</div>
