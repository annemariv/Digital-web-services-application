@model string

<!-- services -->
<section class="services-nav-section py-5">

    <div class="container text-center mb-4">
        <h2 class="services-title">Teenused</h2>
        <p class="services-subtitle">
            Vali teenus ja vaata täpsemalt, kuidas saame aidata.
        </p>
    </div>

    <div class="container d-flex justify-content-center">
        <div class="nav-tabs-container">
            <a href="/teenused/kodulehe-loomine"
               class="nav-tab @(Model == "_Webpage" ? "active" : "")">
                Kodulehe loomine
            </a>

            <a href="/teenused/epoe-loomine"
               class="nav-tab @(Model == "_Estore" ? "active" : "")">
                E-poe loomine
            </a>

            <a href="/teenused/logo-disain"
               class="nav-tab @(Model == "_Design" ? "active" : "")">
                Logo disain
            </a>

            <a href="/teenused/raamatupidamine"
               class="nav-tab @(Model == "_Accounting" ? "active" : "")">
                Raamatupidamine
            </a>

            <a href="/teenused/konsultatsioon"
               class="nav-tab @(Model == "_Consultation" ? "active" : "")">
                Konsultatsioon
            </a>
        </div>
    </div>

</section>


<!-- detail -->
<section class="service-detail py-5">
    <div class="container">
        <div class="row align-items-center g-5">

            <div class="col-md-6 d-flex align-items-center justify-content-center">
                <div class="service-image w-100">
                    <img src="~/images/@ViewData["ImageFile"]" alt="@Model" class="img-fluid rounded shadow-sm">
                </div>
            </div>

            <div class="col-md-6 d-flex">
                <div class="service-text-content p-4 w-100 d-flex flex-column">
                    @await Html.PartialAsync($"~/Views/Services/{Model}.cshtml")
                </div>
            </div>

        </div>
    </div>
</section>

<!-- back to quote section -->
<section class="service-cta-section py-5">
    <div class="container text-center">

        <h2 class="cta-title">Valmis järgmiseks sammuks?</h2>

        <p class="cta-subtitle">
            Küsi hinnapakkumist ja leiame sinu ettevõttele sobiva lahenduse.
        </p>

        @{
            var serviceMap = ViewData["Service"] as string;
        }

        <a href="@(serviceMap != null ? $"/?service={serviceMap}#quote" : "/#quote")"
           class="btn hero-btn mt-3">
            Võte meiega ühendust
        </a>

    </div>
</section>