<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ClientsideWebApp</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ClientsideWebApp.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="page-wrapper d-flex flex-column min-vh-100">
        <header>
            <nav class="site-navbar navbar navbar-expand-lg">
                <div class="container justify-content-center">
                    <a class="site-brand" href="#">[Ettevõtte nimi]</a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="collapse navbar-collapse text-center" id="navbarContent">
                        <ul class="navbar-nav mx-auto">
                            <li class="nav-item">
                                <a class="site-link nav-link active" asp-controller="Home" asp-action="Index">Avaleht</a>
                            </li>
                            <li class="nav-item">
                                <a class="site-link nav-link" asp-controller="Home" asp-fragment="services" asp-action="Index">Teenused</a>
                            </li>
                            <li class="nav-item">
                                <a class="site-link nav-link" asp-controller="Home" asp-action="Contact">Kontakt</a>
                            </li>
                        </ul>
                    </div>
                </div>
            </nav>
        </header>

        <main class="flex-grow-1 container pb-3">
            @RenderBody()
        </main>

        <footer class="glass-footer py-4">
            <div class="container d-flex flex-column flex-md-row justify-content-between align-items-center">
                <div class="footer-copy">
                    &copy; @DateTime.Now.Year [Ettevõtte nimi]
                </div>
                <div class="footer-links mb-3 mb-md-0">
                    <a href="#" class="footer-link">Meist</a>
                    <span class="mx-2">•</span>
                    <a href="#" class="footer-link">Privaatsus</a>
                </div>
                
            </div>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
