<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ClientsideWebApp</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ClientsideWebApp.styles.css" asp-append-version="true" />

    <link rel="apple-touch-icon" sizes="180x180" href="~/images/apple-touch-icon.png?v=1" />
    <link rel="icon" type="image/png" sizes="32x32" href="~/images/favicon-32x32.png?v=1" />
    <link rel="icon" type="image/png" sizes="16x16" href="~/images/favicon-16x16.png?v=1" />
    <link rel="shortcut icon" href="~/favicon.ico?v=1" />
    <meta name="theme-color" content="#c6f08a" />
    <link rel="manifest" href="~/site.webmanifest" />
</head>
<body>
    <div class="page-wrapper d-flex flex-column min-vh-100">
        <header>
            <nav class="site-navbar navbar navbar-expand-lg">
                <div class="container justify-content-center">
                    <a class="site-brand" href="#">
                        <img src="~/images/V_ logo.png" alt="Veltenor OÜ" height="40">
                    </a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="collapse navbar-collapse text-center" id="navbarContent">
                        <ul class="navbar-nav mx-auto">
                            <li class="nav-item">
                                <a class="site-link nav-link active" asp-controller="Home" asp-action="Index">Avaleht</a>
                            </li>
                            <li class="nav-item">
                                <a class="site-link nav-link" asp-controller="Home" asp-fragment="services" asp-action="Index">Teenused</a>
                            </li>
                            <li class="nav-item">
                                <a class="site-link nav-link" asp-controller="Home" asp-action="Contact">Kontakt</a>
                            </li>
                            <li class="nav-item ms-3 d-flex align-items-center">
                                <a class="hero-btn" asp-controller="Home" asp-action="Index" asp-fragment="quote">
                                    Küsi hinnapakkumist
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
            </nav>
        </header>

        <main class="flex-grow-1 pb-3">
            @RenderBody()
        </main>

        <footer class="glass-footer py-5">
            <div class="container d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">

                <div class="footer-copy text-center text-md-start">
                    &copy; @DateTime.Now.Year Veltenor OÜ
                </div>

                <div class="footer-links d-flex gap-3">
                    <a asp-controller="Home" asp-action="Privacy" class="footer-link">Privaatsus</a>
                    <a asp-controller="Home" asp-action="Contact" class="footer-link">Kontakt</a>
                </div>

            </div>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
